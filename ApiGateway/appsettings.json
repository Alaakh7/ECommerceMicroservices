{
  "Gateway": {
    "Name": "ECommerce API Gateway",
    "ExposeRouteDetails": false,
    "UseHttpsRedirection": false
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "X-Correlation-ID", "If-Match", "traceparent", "tracestate", "baggage", "Accept-Language" ],
    "ExposedHeaders": [ "Location", "X-Correlation-ID", "Retry-After", "ETag" ],
    "AllowCredentials": false,
    "PreflightMaxAgeMinutes": 10
  },
  "RateLimiting": {
    "Enabled": true,
    "ReadPolicy": { "PermitLimit": 120, "WindowSeconds": 60, "QueueLimit": 10 },
    "WritePolicy": { "PermitLimit": 60, "WindowSeconds": 60, "QueueLimit": 5 },
    "CriticalPolicy": { "PermitLimit": 20, "WindowSeconds": 60, "QueueLimit": 0 }
  },
  "RequestTimeouts": {
    "DefaultSeconds": 30,
    "ReadSeconds": 15,
    "WriteSeconds": 30,
    "OrderCreationSeconds": 90
  },
  "RequestLimits": {
    "MaximumBodySizeBytes": 1048576,
    "MaximumHeaderCount": 100,
    "MaximumHeadersTotalSizeBytes": 32768,
    "MaximumRequestLineSize": 8192
  },
  "DependencyHealth": {
    "Enabled": true,
    "CheckDependenciesInReadiness": false,
    "TimeoutSeconds": 3,
    "CacheDurationSeconds": 5
  },
  "SecurityHeaders": {
    "ContentTypeOptions": "nosniff",
    "FrameOptions": "DENY",
    "ReferrerPolicy": "no-referrer",
    "PermissionsPolicy": "geolocation=(), microphone=(), camera=()"
  },
  "ForwardedHeaders": {
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "Documentation": {
    "Enabled": false,
    "ExposeDownstreamDocuments": false
  },
  "Authentication": {
    "Enabled": false,
    "Authority": "",
    "Audience": "",
    "RequireHttpsMetadata": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*"
}
