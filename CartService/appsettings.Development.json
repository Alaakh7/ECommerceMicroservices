{
  "ConnectionStrings": {
    "CartDatabase": "Host=localhost;Port=5434;Database=cartdb;Username=cartuser;Password=change_this_password"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "CartExpiration": {
    "Enabled": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "RateLimiting": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
